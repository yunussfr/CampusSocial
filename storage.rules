rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function firestoreDoc(path) {
      return firestore.get(/databases/(default)/documents/$(path));
    }

    match /users/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(userId);
    }

    match /events/{eventId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && firestoreDoc(/events/$(eventId)).data.organizerId == request.auth.uid;
    }

    match /communities/{communityId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn()
        && firestoreDoc(/communities/$(communityId)).data.creatorId == request.auth.uid;
    }

    match /listings/{listingId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && firestoreDoc(/listings/$(listingId)).data.sellerId == request.auth.uid;
    }

    match /chats/{chatId}/messages/{fileName} {
      allow read, write: if signedIn();
    }
  }
}
