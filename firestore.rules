rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function unchangedCounterFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'attendeeCount',
        'likeCount',
        'memberCount',
        'commentCount',
        'viewCount',
        'savedCount',
        'followersCount',
        'followingCount',
      ]);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && unchangedCounterFields();
      allow delete: if false;

      match /follows/{targetId} {
        allow read: if signedIn();
        allow create, delete: if isOwner(userId) && targetId != userId;
        allow update: if false;
      }

      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow create, delete: if false;
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }

      match /savedEvents/{eventId} {
        allow read, create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /savedListings/{listingId} {
        allow read, create, delete: if isOwner(userId);
        allow update: if false;
      }
    }

    match /events/{eventId} {
      allow read: if signedIn() && resource.data.status == 'active';
      allow create: if signedIn()
        && request.resource.data.organizerId == request.auth.uid
        && request.resource.data.attendeeCount == 0
        && request.resource.data.likeCount == 0
        && request.resource.data.status == 'active';
      allow update: if signedIn()
        && resource.data.organizerId == request.auth.uid
        && unchangedCounterFields();
      allow delete: if signedIn() && resource.data.organizerId == request.auth.uid;

      match /attendees/{userId} {
        allow read: if signedIn();
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['userId', 'joinedAt', 'status'])
          && request.resource.data.status in ['confirmed', 'waitlist'];
        allow delete: if isOwner(userId);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      }
    }

    match /communities/{communityId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.creatorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.creatorId == request.auth.uid
        && unchangedCounterFields();
      allow delete: if signedIn() && resource.data.creatorId == request.auth.uid;

      match /members/{userId} {
        allow read: if signedIn();
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /posts/{postId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if signedIn()
          && resource.data.userId == request.auth.uid
          && unchangedCounterFields();

        match /comments/{commentId} {
          allow read: if signedIn();
          allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
          allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
        }
      }
    }

    match /listings/{listingId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.viewCount == 0
        && request.resource.data.savedCount == 0
        && request.resource.data.status == 'active'
        && request.resource.data.imageURLs.size() <= 5;
      allow update: if signedIn()
        && resource.data.sellerId == request.auth.uid
        && unchangedCounterFields();
      allow delete: if signedIn() && resource.data.sellerId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
        allow update: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if false;
      }
    }
  }
}
